/*
 * iter-17: wire the edp_ref_clk (19.2 MHz fixed-clock declared at root)
 * into the eDP PHY so qcom,sc8180x-edp-phy has the reference clock it
 * expects.  Mainline sc8180x.dtsi currently declares only "aux" and
 * "cfg_ahb"; we append "edp_ref" (name matches the sc8280xp mainline
 * precedent and the Ritesh Kumar pending patch).
 */
&edp_phy {
	clocks = <&dispcc DISP_CC_MDSS_EDP_AUX_CLK>,
		 <&dispcc DISP_CC_MDSS_AHB_CLK>,
		 <&edp_ref_clk>;
	clock-names = "aux", "cfg_ahb", "edp_ref";
};

&mdss_edp {
	status = "okay";

	data-lanes = <0 1 2 3>;

	pinctrl-names = "default";
	pinctrl-0 = <&edp_hpd_active>;

	aux-bus {
		/* BOE TE133FHE-TS0 Panel */
		panel {
			compatible = "edp-panel";
			no-hpd;

			// backlight = <&backlight>;

			ports {
				port {
					panel_in: endpoint {
						remote-endpoint = <&mdss_edp_out>;
					};
				};
			};
		};
	};

	ports {
		port@1 {
			reg = <1>;
			mdss_edp_out: endpoint {
				remote-endpoint = <&panel_in>;
			};
		};
	};
};

