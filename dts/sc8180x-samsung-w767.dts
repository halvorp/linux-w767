&spmi_bus {
	pmic@2 {
		status = "disabled";
	};
	pmic@a {
		status = "disabled";
	};
};

&tlmm {
	// gpio-reserved-ranges = <0 4>, <47 4>, <126 4>;
	gpio-reserved-ranges = <0 4>, <126 4>;

	dp0_sbu_sw_en: dp0-sbu-sw-en {
		sel {
			pins = "gpio100";
			function = "gpio";
			output-low;
		};

		oe-n {
			pins = "gpio152";
			function = "gpio";
			output-low;
		};
	};

	dp1_sbu_sw_en: dp1-sbu-sw-en {
		sel {
			pins = "gpio187";
			function = "gpio";
			output-low;
		};

		oe-n {
			pins = "gpio188";
			function = "gpio";
			output-low;
		};
	};

	edp_hpd_active: epd-hpd-active-state {
		pins = "gpio10";
		function = "edp_hot";
	};

	touchscreen_active: touchscreen-active-state {
		pins = "gpio123";
		function = "gpio";

		input-enable;
		bias-pull-up;
		drive-strength = <2>;
	};

	i2c1_active: i2c1-active-state {
		pins = "gpio114", "gpio115";
		function = "qup1";

		bias-pull-up;
		drive-strength = <2>;
	};

	i2c4_active: i2c4-active-state {
		pins = "gpio51", "gpio52";
		function = "qup4";

		bias-pull-up;
		drive-strength = <2>;
	};

	i2c5_active: i2c5-active-state {
		pins = "gpio121", "gpio122";
		function = "qup5";

		bias-pull-up;
		drive-strength = <2>;
	};

	i2c7_active: i2c7-active-state {
		pins = "gpio98", "gpio99";
		function = "qup7";

		bias-pull-up;
		drive-strength = <2>;
	};

	i2c8_active: i2c8-active-state {
		pins = "gpio88", "gpio89";
		function = "qup8";

		bias-pull-up;
		drive-strength = <2>;
	};

	i2c9_active: i2c9-active-state {
		pins = "gpio39", "gpio40";
		function = "qup9";

		bias-pull-up;
		drive-strength = <2>;
	};

	i2c11_active: i2c11-active-state {
		pins = "gpio94", "gpio95";
		function = "qup11";

		bias-pull-up;
		drive-strength = <2>;
	};

	i2c14_active: i2c14-active-state {
		pins = "gpio47", "gpio48";
		function = "qup14";

		bias-pull-up;
		drive-strength = <2>;
	};

	i2c15_active: i2c15-active-state {
		pins = "gpio27", "gpio28";
		function = "qup15";

		bias-pull-up;
		drive-strength = <2>;
	};

	i2c17_active: i2c17-active-state {
		pins = "gpio55", "gpio56";
		function = "qup17";

		bias-pull-up;
		drive-strength = <2>;
	};

	i2c18_active: i2c18-active-state {
		pins = "gpio23", "gpio24";
		function = "qup18";

		bias-pull-up;
		drive-strength = <2>;
	};

	i2c19_active: i2c19-active-state {
		pins = "gpio181", "gpio182";
		function = "qup19";

		bias-pull-up;
		drive-strength = <2>;
	};


	pcie3_default_state: pcie3-default-state {
		clkreq {
			pins = "gpio179";
			function = "pci_e3";
			bias-pull-up;
		};

		reset-n {
			pins = "gpio178";
			function = "gpio";

			drive-strength = <2>;
			output-low;
			bias-pull-down;
		};

		wake-n {
			pins = "gpio180";
			function = "gpio";

			drive-strength = <2>;
			bias-pull-up;
		};
	};

	uart13_state: uart13-state {
		cts {
			pins = "gpio43";
			function = "qup13";
			bias-pull-down;
		};

		rts-tx {
			pins = "gpio44", "gpio45";
			function = "qup13";
			drive-strength = <2>;
			bias-disable;
		};

		rx {
			pins = "gpio46";
			function = "qup13";
			bias-pull-up;
		};
	};
};

&uart13 {
	status = "okay";

	pinctrl-names = "default";
	pinctrl-0 = <&uart13_state>;

	bluetooth {
		compatible = "qcom,wcn3998-bt";

		vddio-supply = <&vreg_s4a_1p8>;
		vddxo-supply = <&vreg_l7a_1p8>;
		vddrf-supply = <&vreg_l9a_1p3>;
		vddch0-supply = <&vreg_l11c_3p3>;
		max-speed = <3200000>;
	};
};

&ufs_mem_hc {
	status = "okay";

	reset-gpios = <&tlmm 190 GPIO_ACTIVE_LOW>;

	vcc-supply = <&vreg_l10e_2p9>;
	vcc-max-microamp = <155000>;

	vccq2-supply = <&vreg_l7e_1p8>;
	vccq2-max-microamp = <425000>;
};

&ufs_mem_phy {
	status = "okay";

	vdda-phy-supply = <&vreg_l5e_0p88>;
	vdda-pll-supply = <&vreg_l3c_1p2>;
};

&usb_mp_hsphy0 {
	status = "okay";
	vdda-pll-supply = <&vreg_l5e_0p88>;
	vdda18-supply = <&vreg_l12a_1p8>;
	vdda33-supply = <&vreg_l16e_3p0>;
};

&usb_mp_hsphy1 {
	status = "okay";
	vdda-pll-supply = <&vreg_l5e_0p88>;
	vdda18-supply = <&vreg_l12a_1p8>;
	vdda33-supply = <&vreg_l16e_3p0>;
};

&usb_mp_qmpphy0 {
	status = "okay";
	vdda-phy-supply = <&vreg_l3c_1p2>;
	vdda-pll-supply = <&vreg_l5e_0p88>;
};

&usb_mp_qmpphy1 {
	status = "okay";
	vdda-phy-supply = <&vreg_l3c_1p2>;
	vdda-pll-supply = <&vreg_l5e_0p88>;
};

&usb_mp {
	status = "okay";

	/*
	 * iter-27: brother's suggestion 1 from
	 * research/2026-05-17-claude-qcxhcifilter-rev.md — try the
	 * single-port compatible instead of the -mp variant.  Probably
	 * a no-op (dwc3-qcom-legacy doesn't branch on compatible string),
	 * but cheap to test.  If iter-27 makes no observable difference,
	 * iter-28 escalates to source-level pr_emerg instrumentation of
	 * dwc3-qcom-legacy probe.
	 */
	compatible = "qcom,sc8180x-dwc3", "qcom,dwc3";

	/*
	 * iter-26: brother's USB-MP probe-failure analysis
	 * (research/2026-05-17-claude-usb-mp-vs-sec-deep.md):
	 *
	 * Mainline sc8180x.dtsi declares 10 interrupts for usb_mp, ending
	 * with `ss_phy_1` (pdc 7) and `ss_phy_2` (pdc 30) -- the SuperSpeed
	 * PHY wake IRQs.  Brother decoded the DSDT's \_SB.USB2._CRS and
	 * confirmed it lists only 9 IRQs: 1 core + 4 Level-SharedAndWake
	 * (pwr_event x2, hs_phy x2) + 4 Edge-SharedAndWake (dp_hs_phy x2,
	 * dm_hs_phy x2).  The two ss_phy_* IRQs are NOT wired on W767 --
	 * Samsung-specific simplification, presumably because the internal
	 * MCU (SPACE v57) is a HS-only device.
	 *
	 * Without this override, dwc3-qcom-legacy's platform_get_irq_byname
	 * lookup for ss_phy_1/ss_phy_2 either returns phantom IRQs or
	 * fails, which is a plausible cause for the probe never reaching
	 * the point of registering with the interconnect (no sync_state
	 * pending line ever mentions a4f8800.usb in iter-25's dmesg).
	 *
	 * Trim to the 8 wake IRQs that actually exist + drop the matching
	 * names.  pwr_event_1/2 + hs_phy_1/2 + dp_hs_phy_1/2 + dm_hs_phy_1/2.
	 */
	interrupts-extended = <&intc GIC_SPI 656 IRQ_TYPE_LEVEL_HIGH>,
			      <&intc GIC_SPI 655 IRQ_TYPE_LEVEL_HIGH>,
			      <&intc GIC_SPI 658 IRQ_TYPE_LEVEL_HIGH>,
			      <&intc GIC_SPI 657 IRQ_TYPE_LEVEL_HIGH>,
			      <&pdc 59 IRQ_TYPE_EDGE_BOTH>,
			      <&pdc 46 IRQ_TYPE_EDGE_BOTH>,
			      <&pdc 71 IRQ_TYPE_EDGE_BOTH>,
			      <&pdc 68 IRQ_TYPE_EDGE_BOTH>;
	interrupt-names = "pwr_event_1", "pwr_event_2",
			  "hs_phy_1",    "hs_phy_2",
			  "dp_hs_phy_1", "dm_hs_phy_1",
			  "dp_hs_phy_2", "dm_hs_phy_2";
};

&usb_mp_dwc3 {
	dr_mode = "host";
};

/*
 * iter-26: the smoking gun for usb_mp not probing on Linux.
 *
 * DSDT declares \_SB.USB2.HSEI as a GpioIo on \_SB.GIO0 pin 0x23 (=35),
 * plus a 1-bit Field MOD1 over it.  Brother grep'd the entire DSDT --
 * nothing in AML writes MOD1.  On Windows, QcXhciFilter8180.sys (a
 * mandatory lower-filter, FeatureScore=80) asserts MOD1=1 to bring the
 * USB2 HS PHY out of reset.  Mainline dwc3-qcom-legacy doesn't know
 * this GPIO exists, so the PHY stays gated and USB never enumerates.
 *
 * USB0 (usb_prim) and USB1 (usb_sec) have NO equivalent GPIO declared
 * in DSDT -- they don't need it.  This is usb_mp specific.
 *
 * Asserting pin 35 high at boot via gpio-hog is the cheapest test for
 * this hypothesis.  If it works, the internal MCU enumerates and the
 * internal keyboard + touchpad come online (per brother's prior round
 * SPACE v57 is a stock USB-HID composite -- usbhid/hid-multitouch
 * bind with no further Linux changes).
 */
&tlmm {
	usb_mp_hsei_hog {
		gpio-hog;
		gpios = <35 GPIO_ACTIVE_HIGH>;
		output-high;
		line-name = "usb_mp_hs_phy_enable";
	};
};

&usb_prim_hsphy {
	status = "okay";

	vdda-pll-supply = <&vreg_l5e_0p88>;
	vdda18-supply = <&vreg_l12a_1p8>;
	vdda33-supply = <&vreg_l16e_3p0>;
};

&usb_prim_qmpphy {
	status = "okay";

	vdda-phy-supply = <&vreg_l3c_1p2>;
	vdda-pll-supply = <&vreg_l5e_0p88>;

	orientation-switch;
};

&usb_prim_qmpphy_out {
	remote-endpoint = <&pmic_glink_con0_ss>;
};

&usb_prim {
	status = "okay";
};

&usb_prim_dwc3 {
	dr_mode = "host";
};

&usb_prim_dwc3_hs {
	remote-endpoint = <&pmic_glink_con0_hs>;
};

&usb_sec_hsphy {
	status = "okay";

	vdda-pll-supply = <&vreg_l5e_0p88>;
	vdda18-supply = <&vreg_l12a_1p8>;
	vdda33-supply = <&vreg_l16e_3p0>;
};

&usb_sec_qmpphy {
	status = "okay";

	vdda-phy-supply = <&vreg_l3c_1p2>;
	vdda-pll-supply = <&vreg_l5e_0p88>;

	orientation-switch;
};

&usb_sec_qmpphy_out {
	remote-endpoint = <&pmic_glink_con1_ss>;
};

&usb_sec {
	status = "okay";
};

&usb_sec_dwc3 {
	dr_mode = "host";
};

&usb_sec_dwc3_hs {
	remote-endpoint = <&pmic_glink_con1_hs>;
};

&wifi {
	status = "okay";

	memory-region = <&wlan_mem>;

	vdd-0.8-cx-mx-supply = <&vreg_l1e_0p75>;
	vdd-1.8-xo-supply = <&vreg_l7a_1p8>;
	vdd-1.3-rfa-supply = <&vreg_l9a_1p3>;
	vdd-3.3-ch0-supply = <&vreg_l11c_3p3>;
	//vdd-3.3-ch1-supply = <&vreg_l10c_3p3>; not used?
};

/* PINCTRL */

&pmc8180c_gpios {
	bl_pwm_default_state: bl-pwm-default-state {
		en {
			pins = "gpio8";
			function = "normal";
		};

		pwm {
			pins = "gpio10";
			function = "func1";
		};
	};
};

/*
 * iter-18: relocate gpu_mem so it stops overlapping Samsung's adsp_mem
 * region.  Mainline sc8180x.dtsi places gpu_mem at 0x98715000/0x2000
 * which falls INSIDE adsp_mem (0x97800000 + 32 MiB = 0x99800000).  That
 * collision causes qcom_q6v5_pas to fail ADSP firmware load with
 * -EINVAL ("error -22 setting up firmware qcadsp8180.mbn").  We shift
 * gpu_mem to Jenneron's original safe location outside the DSP regions.
 * The kernel resolves reserved-memory by the reg property, not by the
 * node unit-address, so the inherited name "memory@98715000" is
 * harmless cosmetic mismatch.
 */
&gpu_mem {
	reg = <0x0 0x9b400000 0x0 0x5000>;   /* 20 KiB, matches Jenneron's working size */
};
