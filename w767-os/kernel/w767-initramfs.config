# w767-os — Phase 2 overlay: standalone initramfs distro.
#
# Layered AFTER base-arm64.config and re-covers the same ground as w767.config,
# with critical modules flipped to =y so we don't lose the network before mdev
# fires hotplug events. WiFi/BT/audio/HID-samsung stay =m — iteration targets.
#
# NOTE: kconfig merge_config.sh with -m processes fragments left→right.
# build-kernel.sh merges base-arm64.config + w767-initramfs.config only;
# entries below that conflict with w767.config win because this is the
# later (and only) board fragment for this target.

# --- Include all of Phase 1 board setup by copy ---
# (merge_config.sh doesn't `include` — we duplicate the Phase 1 settings here
# rather than chain. Kept in sync manually; CI lint TBD.)

# === Critical gates ===
CONFIG_HWSPINLOCK=y
CONFIG_HWSPINLOCK_QCOM=y
CONFIG_MFD_SYSCON=y
CONFIG_AUXILIARY_BUS=y
CONFIG_HID_SUPPORT=y
# iter-19 fix: DRM_MSM depends on PM; without PM=y, the entire MSM display
# stack (DRM_MSM, DRM_PANEL_EDP, DRM_DP_AUX_BUS) gets silently dropped by
# olddefconfig, leaving the kernel with no DRM device and consequently no
# console output on the eDP panel (blank-screen post-systemd-boot).
CONFIG_PM=y
CONFIG_PM_SLEEP=y
CONFIG_SUSPEND=y

# iter-20 fix: even with DRM_MSM=y, the panel takes seconds to fully probe
# (clocks, regulators, IOMMU, panel-edp aux-bus negotiation).  Without an
# early framebuffer driver to take over from the firmware GOP at the
# ExitBootServices() boundary, the screen goes BLACK the instant the kernel
# takes control — and stays that way until DRM_MSM finishes probing.  That
# black gap is mostly indistinguishable from a hang.
#
# Enable simpledrm + sysfb (and fb_efi as a fallback path) so the firmware
# framebuffer is preserved as a generic DRM device immediately, until
# DRM_MSM hands over.  Also enable timestamped printk so we can see WHERE
# initialization is at if anything stalls.
CONFIG_SYSFB=y
CONFIG_DRM_SIMPLEDRM=y
CONFIG_FB_EFI=y
CONFIG_PRINTK_TIME=y
CONFIG_PM_GENERIC_DOMAINS=y
CONFIG_PM_GENERIC_DOMAINS_OF=y
CONFIG_GENERIC_PHY=y
CONFIG_GPIOLIB_IRQCHIP=y
CONFIG_OF=y
CONFIG_OF_ADDRESS=y
CONFIG_OF_IRQ=y
CONFIG_OF_RESERVED_MEM=y
CONFIG_OF_OVERLAY=y
CONFIG_DMADEVICES=y
CONFIG_QCOM_BAM_DMA=y
CONFIG_QCOM_HIDMA=y

# === SoC core =y (same as w767.config) ===
CONFIG_ARCH_QCOM=y
CONFIG_PINCTRL=y
CONFIG_PINCTRL_MSM=y
CONFIG_PINCTRL_SC8180X=y
CONFIG_COMMON_CLK_QCOM=y
CONFIG_SC_GCC_8180X=y
CONFIG_SM_DISPCC_8250=y
CONFIG_SM_GPUCC_8150=y
CONFIG_GPIOLIB=y
CONFIG_SPMI=y
CONFIG_SPMI_MSM_PMIC_ARB=y
CONFIG_QCOM_SMEM=y
CONFIG_QCOM_SCM=y
CONFIG_QCOM_AOSS_QMP=y
CONFIG_QCOM_RPMHPD=y
CONFIG_QCOM_COMMAND_DB=y
CONFIG_QCOM_RPMH=y
CONFIG_QCOM_STATS=y
CONFIG_INTERCONNECT=y
CONFIG_INTERCONNECT_QCOM=y
CONFIG_INTERCONNECT_QCOM_SC8180X=y
CONFIG_IOMMU_SUPPORT=y
CONFIG_ARM_SMMU=y
CONFIG_ARM_SMMU_V3=y
CONFIG_QCOM_IOMMU=y
CONFIG_REMOTEPROC=y
CONFIG_QCOM_Q6V5_COMMON=y
CONFIG_QCOM_Q6V5_PAS=y
CONFIG_QCOM_SYSMON=y
CONFIG_QCOM_RPROC_COMMON=y
CONFIG_QCOM_PIL_INFO=y
CONFIG_MTD=y
CONFIG_RPMSG=y
CONFIG_RPMSG_QCOM_GLINK=y
CONFIG_RPMSG_QCOM_GLINK_SMEM=y
CONFIG_QCOM_APCS_IPC=y

# === Storage, USB host, input, display, PHYs =y ===
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_SCSI_UFSHCD=y
CONFIG_SCSI_UFSHCD_PLATFORM=y
CONFIG_SCSI_UFS_QCOM=y
CONFIG_USB_SUPPORT=y
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_XHCI_PLATFORM=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_QCOM=y
CONFIG_USB_CONN_GPIO=y
CONFIG_USB_ROLE_SWITCH=y
CONFIG_TYPEC=y
CONFIG_TYPEC_QCOM_PMIC=y
CONFIG_HID=y
CONFIG_HID_GENERIC=y
CONFIG_USB_HID=y
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_MOUSE=y
CONFIG_SERIAL_QCOM_GENI=y
CONFIG_SERIAL_QCOM_GENI_CONSOLE=y
CONFIG_QCOM_GENI_SE=y
CONFIG_I2C=y
CONFIG_I2C_QCOM_GENI=y
CONFIG_SPI=y
CONFIG_SPI_QCOM_GENI=y
CONFIG_REGULATOR_QCOM_RPMH=y
CONFIG_REGULATOR_QCOM_SPMI=y
CONFIG_POWER_SUPPLY=y
CONFIG_POWER_RESET=y
CONFIG_POWER_RESET_QCOM_PON=y
CONFIG_DRM=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_PANEL=y
CONFIG_DRM_PANEL_EDP=y
CONFIG_DRM_DP_AUX_BUS=y
CONFIG_DRM_MSM=y
CONFIG_DRM_MSM_DP=y
CONFIG_DRM_DISPLAY_HELPER=y
CONFIG_DRM_DISPLAY_DP_HELPER=y
CONFIG_BACKLIGHT_CLASS_DEVICE=y
CONFIG_FB=y
CONFIG_FB_CORE=y
CONFIG_FB_DEVICE=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_PHY_QCOM_EDP=y
CONFIG_PHY_QCOM_QMP=y
CONFIG_PHY_QCOM_QMP_COMBO=y
CONFIG_PHY_QCOM_QMP_USB=y
CONFIG_PHY_QCOM_QMP_UFS=y
CONFIG_PHY_QCOM_USB_SNPS_FEMTO_V2=y
CONFIG_PHY_QCOM_USB_HS=y
CONFIG_QCOM_LLCC=y

# ====================================================================
# Phase 2 CHANGES vs Phase 1:
#   - USB-Ethernet is =y (not =m) so network comes up before userspace/mdev.
#   - MMC for µSD recovery is =y.
# ====================================================================

CONFIG_USB_NET_DRIVERS=y
CONFIG_USB_USBNET=y
CONFIG_USB_NET_CDCETHER=y
CONFIG_USB_NET_CDC_NCM=y
CONFIG_USB_NET_CDC_EEM=y
CONFIG_USB_RTL8152=y
CONFIG_USB_RTL8153_ECM=y
CONFIG_USB_NET_AX8817X=y
CONFIG_USB_NET_AX88179_178A=y

CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_MSM=y

# ====================================================================
# Still =m — iteration targets.
# ====================================================================

CONFIG_WIRELESS=y
CONFIG_WLAN=y
CONFIG_CFG80211=m
CONFIG_MAC80211=m
CONFIG_RFKILL=y
CONFIG_ATH_COMMON=m
CONFIG_ATH10K=m
CONFIG_ATH10K_SNOC=m
CONFIG_ATH10K_PCI=m
CONFIG_BT=m
CONFIG_BT_HCIUART=m
CONFIG_BT_HCIUART_SERDEV=y
CONFIG_BT_HCIUART_QCA=y
CONFIG_SERIAL_DEV_BUS=y
CONFIG_SOUND=m
CONFIG_SND=m
CONFIG_SND_SOC=m
CONFIG_SND_SOC_SM8250=m
CONFIG_SND_SOC_QDSP6=m
CONFIG_SND_SOC_WCD934X=m
CONFIG_SND_SOC_LPASS_CPU=m
CONFIG_SND_SOC_LPASS_PLATFORM=m
CONFIG_HID_SAMSUNG=m
CONFIG_HID_MULTITOUCH=m

# iter-21: Phase 2 minimal initramfs has no udev/mdev — modules don't
# auto-load on hot-plug. The touchpad will silently never probe if these
# are =m, even with the correct DSDT address from commit 07233d6.
# Brother's pre-boot audit (research/2026-05-17-claude-pre-boot-audit.md)
# explicitly recommended this flip for first-boot bring-up.
CONFIG_I2C_HID=y
CONFIG_I2C_HID_OF=y
