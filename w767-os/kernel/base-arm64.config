# w767-os — architecture-level arm64 config fragment
# Shared by Phase 1 (w767.config) and Phase 2 (w767-initramfs.config).
# Applied on top of `make allnoconfig` via scripts/kconfig/merge_config.sh.

# --- Core arm64 platform ---
CONFIG_64BIT=y
CONFIG_ARM64=y
CONFIG_SMP=y
CONFIG_ARM64_VA_BITS_48=y
CONFIG_ARM64_PAGE_SHIFT=12
CONFIG_MULTIUSER=y
CONFIG_SHMEM=y
CONFIG_PRINTK=y
CONFIG_BUG=y

# --- Preemption & timing ---
CONFIG_PREEMPT=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_NO_HZ_COMMON=y
CONFIG_NO_HZ_IDLE=y

# --- Binary formats (CRITICAL) ---
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y

# --- Essential syscalls / IPC ---
CONFIG_ELF_CORE=y
CONFIG_FUTEX=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_AIO=y
CONFIG_IO_URING=y
CONFIG_INOTIFY_USER=y
CONFIG_POSIX_TIMERS=y
CONFIG_ADVISE_SYSCALLS=y
CONFIG_MEMFD_CREATE=y

# --- Initramfs ---
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y
CONFIG_RD_ZSTD=y

# --- Filesystems ---
CONFIG_BLOCK=y
CONFIG_EXT4_FS=y
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_PROC_SYSCTL=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_DEVPTS_FS=y
CONFIG_CONFIGFS_FS=y

# --- EFI boot (UEFI stub on arm64) ---
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_EFI_ZBOOT=y
CONFIG_EFI_PARTITION=y
CONFIG_RELOCATABLE=y

# --- TTY / VT ---
CONFIG_TTY=y
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_UNIX98_PTYS=y

# --- Networking baseline ---
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_NETDEVICES=y
CONFIG_NETFILTER=y
CONFIG_NETFILTER_XTABLES=y

# --- Namespaces (handy even on bring-up hardware) ---
CONFIG_NAMESPACES=y
CONFIG_NET_NS=y
CONFIG_USER_NS=y

# --- Modules (Phase 2 overlay may turn MODULES=n off; default is on) ---
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODULE_FORCE_UNLOAD=y

# --- Firmware loading ---
CONFIG_FW_LOADER=y
CONFIG_FW_LOADER_COMPRESS=y
CONFIG_FW_LOADER_COMPRESS_XZ=y
CONFIG_FW_LOADER_COMPRESS_ZSTD=y

# --- Crypto baseline ---
CONFIG_CRYPTO=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRC32=y

# --- Compression ---
CONFIG_ZLIB_INFLATE=y
CONFIG_ZLIB_DEFLATE=y
CONFIG_XZ_DEC=y
CONFIG_ZSTD_COMPRESS=y
CONFIG_ZSTD_DECOMPRESS=y

# --- Clocks / regulators / mailbox framework ---
CONFIG_COMMON_CLK=y
CONFIG_REGULATOR=y
CONFIG_REGULATOR_FIXED_VOLTAGE=y
CONFIG_MAILBOX=y

# --- Debug / driver-dev essentials ---
CONFIG_DYNAMIC_DEBUG=y
CONFIG_FTRACE=y
CONFIG_FUNCTION_TRACER=y
CONFIG_MAGIC_SYSRQ=y
CONFIG_DEBUG_INFO=y
CONFIG_DEBUG_INFO_DWARF5=y
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=y

# --- Crash capture (no serial console — we rely on pstore) ---
CONFIG_KEXEC=y
CONFIG_CRASH_DUMP=y
CONFIG_PSTORE=y
CONFIG_PSTORE_RAM=y
CONFIG_PSTORE_CONSOLE=y
CONFIG_PSTORE_PMSG=y

# --- Security: DISABLE noisy options during bring-up ---
# CONFIG_IMA is not set
# CONFIG_EVM is not set
# CONFIG_TCG_TPM is not set
# CONFIG_SECURITY_SELINUX is not set
# CONFIG_SECURITY_APPARMOR is not set
# CONFIG_AUDIT is not set
