# w767-os — Phase 1 overlay for Samsung Galaxy Book S (SM-W767, SC8180X).
#
# Goal: boot this custom kernel beside Fedora's iter-17 kernel, using Fedora's
# rootfs. Built-ins cover what must be alive before userspace; modules stay
# modular for hot `rmmod`/`insmod` iteration.

# --- Critical gates (allnoconfig leaves these off; many dependent drivers are
#     silently dropped without them). ---
CONFIG_HWSPINLOCK=y
CONFIG_HWSPINLOCK_QCOM=y
CONFIG_MFD_SYSCON=y
CONFIG_AUXILIARY_BUS=y
CONFIG_HID_SUPPORT=y
CONFIG_PM_GENERIC_DOMAINS=y
CONFIG_PM_GENERIC_DOMAINS_OF=y
CONFIG_GENERIC_PHY=y
CONFIG_GPIOLIB_IRQCHIP=y
CONFIG_OF=y
CONFIG_OF_ADDRESS=y
CONFIG_OF_IRQ=y
CONFIG_OF_RESERVED_MEM=y
CONFIG_OF_OVERLAY=y
CONFIG_DMADEVICES=y
CONFIG_QCOM_BAM_DMA=y
CONFIG_QCOM_HIDMA=y

# --- SoC platform glue (all =y, required for probe order) ---
CONFIG_ARCH_QCOM=y
CONFIG_PINCTRL=y
CONFIG_PINCTRL_MSM=y
CONFIG_PINCTRL_SC8180X=y
CONFIG_COMMON_CLK_QCOM=y
CONFIG_SC_GCC_8180X=y
CONFIG_SM_DISPCC_8250=y
CONFIG_SM_GPUCC_8150=y
CONFIG_GPIOLIB=y
CONFIG_SPMI=y
CONFIG_SPMI_MSM_PMIC_ARB=y
CONFIG_QCOM_SMEM=y
CONFIG_QCOM_SCM=y
CONFIG_QCOM_AOSS_QMP=y
CONFIG_QCOM_RPMHPD=y
CONFIG_QCOM_COMMAND_DB=y
CONFIG_QCOM_RPMH=y
CONFIG_QCOM_STATS=y
CONFIG_INTERCONNECT=y
CONFIG_INTERCONNECT_QCOM=y
CONFIG_INTERCONNECT_QCOM_SC8180X=y

# --- IOMMU ---
CONFIG_IOMMU_SUPPORT=y
CONFIG_ARM_SMMU=y
CONFIG_ARM_SMMU_V3=y
CONFIG_QCOM_IOMMU=y

# --- Remoteproc (ADSP/CDSP/SLPI/MSS) + RPMSG ---
CONFIG_REMOTEPROC=y
CONFIG_QCOM_Q6V5_COMMON=y
CONFIG_QCOM_Q6V5_PAS=y
CONFIG_QCOM_SYSMON=y
CONFIG_QCOM_RPROC_COMMON=y
CONFIG_QCOM_PIL_INFO=y
CONFIG_MTD=y
CONFIG_RPMSG=y
CONFIG_RPMSG_QCOM_GLINK=y
CONFIG_RPMSG_QCOM_GLINK_SMEM=y
CONFIG_QCOM_APCS_IPC=y

# --- UFS (root disk for iter-17's Fedora rootfs) ---
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_SCSI_UFSHCD=y
CONFIG_SCSI_UFSHCD_PLATFORM=y
CONFIG_SCSI_UFS_QCOM=y

# --- USB host (=y so a USB-Ethernet dongle enumerates before userspace) ---
CONFIG_USB_SUPPORT=y
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_XHCI_PLATFORM=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_QCOM=y
CONFIG_USB_CONN_GPIO=y
CONFIG_USB_ROLE_SWITCH=y
CONFIG_TYPEC=y
CONFIG_TYPEC_QCOM_PMIC=y

# --- Input core (=y; HID-Samsung quirks remain =m) ---
CONFIG_HID=y
CONFIG_HID_GENERIC=y
CONFIG_USB_HID=y
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_MOUSE=y

# --- Console / serial (GENI UARTs) ---
CONFIG_SERIAL_QCOM_GENI=y
CONFIG_SERIAL_QCOM_GENI_CONSOLE=y

# --- GENI / I2C / SPI (QUP wrappers) ---
CONFIG_QCOM_GENI_SE=y
CONFIG_I2C=y
CONFIG_I2C_QCOM_GENI=y
CONFIG_SPI=y
CONFIG_SPI_QCOM_GENI=y

# --- Regulators on PMIC ---
CONFIG_REGULATOR_QCOM_RPMH=y
CONFIG_REGULATOR_QCOM_SPMI=y

# --- Power ---
CONFIG_POWER_SUPPLY=y
CONFIG_POWER_RESET=y
CONFIG_POWER_RESET_QCOM_PON=y
CONFIG_PM=y
CONFIG_PM_SLEEP=y

# --- Display (=y; firmware-order race hurt us as module) ---
CONFIG_DRM=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_PANEL=y
CONFIG_DRM_PANEL_EDP=y
CONFIG_DRM_DP_AUX_BUS=y
CONFIG_DRM_MSM=y
CONFIG_DRM_MSM_DP=y
CONFIG_DRM_DISPLAY_HELPER=y
CONFIG_DRM_DISPLAY_DP_HELPER=y
CONFIG_BACKLIGHT_CLASS_DEVICE=y
CONFIG_BACKLIGHT_PWM=y

# --- Framebuffer (for w767_init bootlog painter) ---
CONFIG_FB=y
CONFIG_FB_CORE=y
CONFIG_FB_DEVICE=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE_DETECT_PRIMARY=y

# --- PHYs ---
CONFIG_PHY_QCOM_EDP=y
CONFIG_PHY_QCOM_QMP=y
CONFIG_PHY_QCOM_QMP_COMBO=y
CONFIG_PHY_QCOM_QMP_PCIE=y
CONFIG_PHY_QCOM_QMP_UFS=y
CONFIG_PHY_QCOM_QMP_USB=y
CONFIG_PHY_QCOM_USB_SNPS_FEMTO_V2=y
CONFIG_PHY_QCOM_USB_HS=y

# --- GPU cache / UBWC ---
CONFIG_QCOM_LLCC=y

# --- pstore backend wiring ---
CONFIG_PSTORE_RAM=y

# ====================================================================
# Modules — hot iteration targets
# ====================================================================

# --- Wi-Fi (WCN3990 via ath10k_snoc) ---
CONFIG_WIRELESS=y
CONFIG_WLAN=y
CONFIG_CFG80211=m
CONFIG_MAC80211=m
CONFIG_RFKILL=y
CONFIG_ATH_COMMON=m
CONFIG_ATH10K=m
CONFIG_ATH10K_SNOC=m
CONFIG_ATH10K_PCI=m

# --- Bluetooth (WCN3990 over serdev / qca) ---
# BT_HCIUART_QCA is `bool`, not tristate — =y is the only valid value.
# BT_QCA is a hidden helper auto-selected by BT_HCIUART_QCA.
CONFIG_BT=m
CONFIG_BT_HCIUART=m
CONFIG_BT_HCIUART_SERDEV=y
CONFIG_BT_HCIUART_QCA=y
CONFIG_SERIAL_DEV_BUS=y

# --- Audio: QDSP6 + WCD9341 + LPASS (no per-board SC8180X machine driver in mainline v7.0;
#     closest is SM8250 for the clocks and QDSP6 for the DSP). Keep modular —
#     this stack is a Phase-3 iteration target.
CONFIG_SOUND=m
CONFIG_SND=m
CONFIG_SND_TIMER=m
CONFIG_SND_PCM=m
CONFIG_SND_HWDEP=m
CONFIG_SND_SOC=m
CONFIG_SND_SOC_SM8250=m
CONFIG_SND_SOC_QDSP6=m
CONFIG_SND_SOC_WCD934X=m
CONFIG_SND_SOC_LPASS_CPU=m
CONFIG_SND_SOC_LPASS_PLATFORM=m
CONFIG_SLIMBUS=m
CONFIG_SLIM_QCOM_CTRL=m
CONFIG_SLIM_QCOM_NGD_CTRL=m

# --- Samsung HID quirks (active fix target — broken composite KB) ---
# HID_SUPPORT must be =y above for these to be available.
CONFIG_HID_SAMSUNG=m
CONFIG_HID_MULTITOUCH=m
CONFIG_I2C_HID=m
CONFIG_I2C_HID_OF=m
CONFIG_BT_HCIBTUSB=m
CONFIG_BT_HCIBTUSB_MTK=n
CONFIG_BT_HCIUART_BCSP=y
CONFIG_BT_HCIUART_H4=y
CONFIG_BT_HCIUART_3WIRE=y

# --- USB-Ethernet (CRITICAL — dongle is Phase 1/2 network) ---
CONFIG_USB_NET_DRIVERS=m
CONFIG_USB_USBNET=m
CONFIG_USB_NET_CDCETHER=m
CONFIG_USB_NET_CDC_NCM=m
CONFIG_USB_NET_CDC_EEM=m
CONFIG_USB_RTL8152=m
CONFIG_USB_RTL8153_ECM=m
CONFIG_USB_NET_AX8817X=m
CONFIG_USB_NET_AX88179_178A=m

# --- USB mass storage (µSD recovery path) ---
CONFIG_USB_STORAGE=m

# --- MMC (µSD slot) ---
CONFIG_MMC=m
CONFIG_MMC_BLOCK=m
CONFIG_MMC_SDHCI=m
CONFIG_MMC_SDHCI_MSM=m

# --- Fat/VFAT for compatibility with dongle adapters + boot tools ---
CONFIG_VFAT_FS=m
CONFIG_FAT_FS=m
CONFIG_MSDOS_FS=m
CONFIG_NLS=y
CONFIG_NLS_CODEPAGE_437=m
CONFIG_NLS_ISO8859_1=m
CONFIG_NLS_UTF8=m
